# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Security key for the administration panel inside the manager dashboard
# Default fallback is 'admin123' if not specified
ADMIN_PASSWORD="MySecureAdminPassword123"

# VERCEL KV CONFIGURATION: Standard Upstash Redis REST credentials.
# Link your Vercel Project with your KV Store to obtain these variables automatically.
KV_REST_API_URL="https://your-database-id.upstash.io"
KV_REST_API_TOKEN="your_redis_rest_api_bearer_token"
